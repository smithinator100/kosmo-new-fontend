{
  "name": "kosmo-new",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/prototype",
    "build": "npm run build --workspace=packages/kosmo-ui && npm run build --workspace=apps/prototype",
    "build:ui": "npm run build --workspace=packages/kosmo-ui",
    "build:prototype": "npm run build --workspace=apps/prototype",
    "preview": "npm run preview --workspace=apps/prototype",
    "test": "npm run test --workspace=packages/kosmo-ui",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
