{
  "name": "@kosmo/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Kosmo design system: typed vanilla-TS UI primitives + design tokens.",
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/kosmo-ui.cjs",
  "module": "./dist/kosmo-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/kosmo-ui.js",
      "require": "./dist/kosmo-ui.cjs"
    },
    "./styles.css": "./dist/kosmo-ui.css",
    "./tokens.css": "./src/tokens/index.css",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run && tsc -p tsconfig.types-tests.json",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.types-tests.json",
    "docs:extract": "tsx scripts/extract-props.ts"
  },
  "peerDependencies": {
    "lucide": ">=0.500.0"
  },
  "peerDependenciesMeta": {
    "lucide": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "axe-core": "^4.10.2",
    "happy-dom": "^15.11.7",
    "lucide": "^0.577.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.8"
  }
}
